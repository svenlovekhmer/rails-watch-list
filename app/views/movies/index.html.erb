<div class="container py-5">
  <div class="d-flex justify-content-between align-items-end mb-5">
    <div>
      <p class="text-uppercase text-muted fw-semibold mb-1">
        Movie library
      </p>
      <h1 class="display-5 fw-bold mb-2">
        Top rated movies
      </h1>
      <p class="text-muted mb-0">
        Browse your collection and discover great movies.
      </p>
    </div>
  </div>
  <div class="row g-4">
    <% @movies.each do |movie| %>
      <div class="col-sm-6 col-lg-4 col-xl-3">
        <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
          <div class="position-relative">
            <%= image_tag movie.poster_url,
                  class: "card-img-top",
                  style: "height: 360px; object-fit: cover;" %>
            <span class="position-absolute top-0 end-0 m-3 badge rounded-pill text-bg-dark">
              <i class="fa-solid fa-star text-warning me-1"></i>
              <%= movie.rating.round(1) %>
            </span>
              <button
                class="position-absolute top-0 start-0 m-3 badge rounded-pill text-bg-dark border-0"
                data-bs-toggle="modal"
                data-bs-target="#addToListModal-<%= movie.id %>"
              >
                <i class="fa-solid fa-plus me-1"></i>
                Add to list
              </button>
          </div>
          <div class="card-body d-flex flex-column p-4">
            <h2 class="h5 fw-bold mb-2">
              <%= movie.title %>
            </h2>
            <p class="text-muted small flex-grow-1">
              <%= truncate(movie.overview, length: 130) %>
            </p>
            <div class="d-flex justify-content-between align-items-center mt-3">
              <span class="text-muted small">
                <i class="fa-solid fa-film me-1"></i>
                Movie
              </span>
            </div>
          </div>
        </div>
      </div>
      <div class="modal fade"
     id="addToListModal-<%= movie.id %>"
     tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
          <div class="modal-content rounded-4 border-0 shadow">
            <div class="modal-header bg-dark text-white">
              <h5 class="modal-title">
                Add "<%= movie.title %>"
              </h5>
              <button
                type="button"
                class="btn-close btn-close-white"
                data-bs-dismiss="modal">
              </button>
            </div>
            <div class="modal-body">
              <% List.all.each do |list| %>
                <%= button_to list_bookmarks_path(list),
                      params: {
                        bookmark: {
                          movie_ids: [movie.id],
                          comment: "Added from movie page"
                        }
                      },
                      method: :post,
                      class: "btn btn-light w-100 text-start mb-2 rounded-3 p-3" do %>
                  <i class="fa-solid fa-layer-group me-2"></i>
                  <%= list.name %>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>

    <% end %>
  </div>
</div>

<div
  class="position-relative overflow-hidden rounded-4 mb-5"
  style="height: 380px;"
>
  <% if @list.movies.any? %>
    <%= image_tag @list.movies.sample.poster_url,
          class: "w-100 h-100",
          style: "object-fit: cover;" %>
  <% else %>
    <div
      class="w-100 h-100"
      style="
        background:
        linear-gradient(
        135deg,
        #1f1f1f 0%,
        #343a40 100%
        );
      "
    ></div>
  <% end %>
  <div
    class="position-absolute top-0 start-0 w-100 h-100"
    style="
      background:
      linear-gradient(
      to top,
      rgba(0,0,0,0.85),
      rgba(0,0,0,0.25)
      );
    "
  ></div>
  <div class="position-absolute top-0 start-0 w-100 p-4">
    <%= link_to lists_path,
          class: "btn btn-light rounded-pill shadow-sm px-4" do %>
      <i class="fa-solid fa-arrow-left me-2"></i>
      Back
    <% end %>
  </div>
  <div class="position-absolute bottom-0 start-0 w-100 p-5 text-white">
    <p class="text-uppercase text-white-50 fw-semibold mb-2">
      Movie Collection
    </p>
    <h1 class="display-3 fw-bold mb-3">
      <%= @list.name %>
    </h1>
    <div class="d-flex align-items-center gap-4">
      <span class="badge rounded-pill text-bg-dark px-3 py-2">
        <i class="fa-solid fa-film me-2"></i>
        <%= pluralize(@list.movies.count, "movie") %>
      </span>
      <button
        type="button"
        class="btn btn-light rounded-pill px-4 shadow-sm"
        data-bs-toggle="modal"
        data-bs-target="#addMovieModal"
      >
        <i class="fa-solid fa-plus me-2"></i>
        Add movie
      </button>
    </div>
  </div>
</div>
<div class="container py-5">
  <div class="d-flex justify-content-between align-items-end mb-5">
    <div>
      <p class="text-uppercase text-muted fw-semibold mb-1">Movie list</p>
      <h1 class="display-5 fw-bold mb-2"><%= @list.name %></h1>
      <p class="text-muted mb-0">
        <%= pluralize(@list.bookmarks.count, "movie") %> in this collection
      </p>
    </div>
    <button
      type="button"
      class="btn btn-dark rounded-pill px-4"
      data-bs-toggle="modal"
      data-bs-target="#addMovieModal"
    >
      <i class="fa-solid fa-plus me-2"></i>
      Add movie
    </button>
  </div>
  <% if @list.bookmarks.empty? %>
    <div class="text-center py-5">
      <i class="fa-solid fa-film fs-1 text-muted mb-4"></i>
      <h2 class="h3 fw-bold">No movies yet</h2>
      <p class="text-muted">Add your first movie to this list.</p>
    </div>
  <% else %>
    <div class="row g-4">
      <% @list.bookmarks.each do |bookmark| %>
        <div class="col-sm-6 col-lg-4 col-xl-3">
          <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden">
            <%= image_tag bookmark.movie.poster_url,
                  class: "card-img-top",
                  style: "height: 360px; object-fit: cover;" %>
            <div class="card-body d-flex flex-column p-4">
              <h2 class="h5 fw-bold mb-2"><%= bookmark.movie.title %></h2>
              <p class="text-muted small flex-grow-1">
                <%= truncate(bookmark.movie.overview, length: 120) %>
              </p>
              <p class="small fst-italic text-muted border-start ps-3">
                “<%= bookmark.comment %>”
              </p>
              <div class="d-flex justify-content-between align-items-center mt-3">
                <span class="badge rounded-pill text-bg-dark">
                  <i class="fa-solid fa-star text-warning me-1"></i>
                  <%= bookmark.movie.rating.round(1) %>
                </span>

                <%= link_to bookmark_path(bookmark),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Remove this movie?"
                      },
                      class: "text-danger" do %>
                  <i class="fa-regular fa-trash-can"></i>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
  <div class="mt-5">
    <%= link_to "← Back to lists",
          lists_path,
          class: "btn btn-outline-secondary rounded-pill px-4" %>
  </div>
</div>
<div class="modal fade" id="addMovieModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable">
    <div class="modal-content border-0 rounded-4 shadow">
      <div class="modal-header bg-dark text-white p-4">
        <div>
          <h5 class="modal-title fw-bold">Add a movie</h5>
          <p class="mb-0 text-white-50 small">
            Pick one movie and add a short comment.
          </p>
        </div>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
      </div>
      <%= simple_form_for [@list, @bookmark] do |f| %>
        <div class="modal-body p-4" style="max-height: 70vh; overflow-y: auto;">
          <div class="row g-3 mb-4">
            <% @available_movies.order(:title).each do |movie| %>
              <div class="col-md-6">
                <label class="movie-option card border-0 shadow-sm rounded-4 overflow-hidden h-100">
                  <%= check_box_tag "bookmark[movie_ids][]",
                    movie.id,
                    false,
                    class: "d-none" %>
                  <div class="row g-0 h-100">
                    <div class="col-4">
                      <%= image_tag movie.poster_url,
                            class: "w-100 h-100",
                            style: "object-fit: cover; min-height: 150px;" %>
                    </div>
                    <div class="col-8">
                      <div class="card-body h-100 d-flex flex-column justify-content-between">
                        <div>
                          <h6 class="fw-bold mb-2"><%= movie.title %></h6>
                          <p class="text-muted small mb-3">
                            <%= truncate(movie.overview, length: 90) %>
                          </p>
                        </div>
                        <div class="d-flex justify-content-between align-items-center">
                          <span class="badge rounded-pill text-bg-dark">
                            <i class="fa-solid fa-star text-warning me-1"></i>
                            <%= movie.rating.round(1) %>
                          </span>

                          <span class="btn btn-sm btn-outline-dark rounded-pill px-3">
                            <i class="fa-solid fa-plus me-1"></i>
                            Add
                          </span>
                        </div>
                      </div>
                    </div>
                  </div>
                </label>
              </div>
            <% end %>
          </div>
          <%= f.input :comment,
                label: "Comment",
                placeholder: "Why do you recommend this movie?",
                input_html: {
                  class: "rounded-3",
                  rows: 3
                } %>
        </div>
        <div class="modal-footer p-4">
          <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">
            Cancel
          </button>
          <%= f.button :submit,
                "Add selected movie",
                class: "btn btn-dark rounded-pill px-4" %>
        </div>
      <% end %>
    </div>
  </div>
</div>

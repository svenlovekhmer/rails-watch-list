<div class="container py-5">
  <div class="d-flex justify-content-between align-items-end mb-5">
    <div>
      <p class="text-uppercase text-muted fw-semibold mb-1">
        Movie collections
      </p>
      <h1 class="display-5 fw-bold mb-2">
        Your Lists
      </h1>
      <p class="text-muted mb-0">
        Organize your favorite movies into beautiful collections.
      </p>
    </div>
    <%= link_to new_list_path,
          class: "btn btn-dark rounded-pill px-4 py-2 shadow-sm" do %>
      <i class="fa-solid fa-plus me-2"></i>
      New list
    <% end %>
  </div>
  <% if @lists != nil %>
  <div class="row g-4">
    <% @lists.each do |list| %>
      <div class="col-md-6 col-xl-4">
        <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100">
          <div
            class="bg-dark text-white p-5 d-flex flex-column justify-content-between"
            style="min-height: 220px;
                   background:
                   linear-gradient(
                   135deg,
                   #1f1f1f 0%,
                   #343a40 100%
                   );"
          >
            <div class="d-flex justify-content-between align-items-start">
              <span class="badge rounded-pill text-bg-light">
                <%= pluralize(list.bookmarks.count, "movie") %>
              </span>
              <div class="d-flex gap-3">
                <%= link_to edit_list_path(list),
                      class: "text-white fs-5" do %>
                  <i class="fa-solid fa-pen-to-square"></i>
                <% end %>
                <%= link_to list_path(list),
                      data: {
                        turbo_method: :delete,
                        turbo_confirm: "Delete this list?"
                      },
                      class: "text-danger fs-5" do %>

                  <i class="fa-regular fa-trash-can"></i>

                <% end %>
              </div>
            </div>
            <div>
              <h2 class="display-6 fw-bold mb-3">
                <%= list.name %>
              </h2>
              <%= link_to "Open list",
                    list_path(list),
                    class: "btn btn-light rounded-pill px-4" %>
            </div>
          </div>
        </div>
      </div>
    <% end %>
  </div>
  <% end %>
</div>

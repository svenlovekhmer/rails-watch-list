<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
        <div
          class="bg-dark text-white p-5"
          style="
            background:
            linear-gradient(
            135deg,
            #1f1f1f 0%,
            #343a40 100%
            );
          "
        >
          <p class="text-uppercase text-white-50 fw-semibold mb-2">
            Movie collections
          </p>
          <h1 class="display-6 fw-bold mb-2">
            <%= title %>
          </h1>
          <p class="mb-0 text-white-50">
            Build your own curated movie collection.
          </p>
        </div>
        <div class="card-body p-5">
          <%= simple_form_for @list do |f| %>
            <div class="mb-4">
              <%= f.input :name,
                    label: "List name",
                    placeholder: "e.g. Sci-Fi classics",
                    input_html: {
                      class: "form-control-lg rounded-3"
                    } %>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-5">
              <%= link_to lists_path,
                    class: "btn btn-outline-secondary rounded-pill px-4" do %>
                <i class="fa-solid fa-arrow-left me-2"></i>
                Back
              <% end %>
              <%= f.button :submit,
                    button_text,
                    class: "btn btn-dark rounded-pill px-4 py-2 shadow-sm" %>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
